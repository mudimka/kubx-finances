{
    "require": {
        "nette/php-generator": "^3.2",
        "symfony/console": "^4.1",
        "doctrine/event-manager": "^1.1",
        "menarasolutions/geographer": "^0.3.13",
        "hflabs/dadata": "22.3.0",
        "phpoffice/phpspreadsheet": "^1.28"
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "replace": {
        "psr/log":  "*",
        "psr/container":  "*",
        "psr/http-client":  "*",
        "psr/http-message":  "*"
    },
    "autoload": {
        "psr-4": {
            "Legacy\\": "classes/",
            "Legacy\\API\\": "api/classes/",
            "Console\\": "console/"
        }
    }
}
